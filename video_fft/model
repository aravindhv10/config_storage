  def list_path_file_bin_2_path_file_infer_json(
      list_path_file_bin_input,
      size_batch=4,
      path_file_model_ckpt_input="/data/input/model.ckpt",
  ):
      def add_path_file_json_2_path_file_bin(x):
          return (
              x,
              convert_path_file_bin_2_path_file_json(x),
          )

      def only_get_uninferred_files(x):
          return not os.path.exists(x[1])

      def do_final_write(path_file_tuple, pred):
          path_file_json = path_file_tuple[1]

          outdict = {
              "P_no_RD": pred[0].item(),
              "P_moderate_RD": pred[1].item(),
              "P_full_RD": pred[2].item(),
          }

          safe_write_dict_to_json(
              indict=outdict,
              path_file_tmp=path_file_json + ".tmp",
              path_file_json_output=path_file_json,
          )

          return path_file_json

      list_path_file_tuple_output = map(
          add_path_file_json_2_path_file_bin,
          list_path_file_bin_input,
      )

      list_path_file_tuple_output = filter(
          only_get_uninferred_files,
          list_path_file_tuple_output,
      )

      list_path_file_tuple_output = list(list_path_file_tuple_output)

      length = len(list_path_file_tuple_output)

      current_ckpt = None
      current_size_batch = None

      for begin in range(0, length, size_batch):
          end = min(begin + size_batch, length)

          batch_path_file_tuple_output = list_path_file_tuple_output[begin:end]
          required_batch_size = len(batch_path_file_tuple_output)

          if current_ckpt is None:
              path_file_input_model_pt2 = export_checkpoint(
                  path_file_input_lightning_ckpt=path_file_model_ckpt_input,
                  path_file_output_compiled_pt2=None,
                  batch_size=required_batch_size,
              )

              current_ckpt = torch._inductor.aoti_load_package(path_file_input_model_pt2)
              current_size_batch = required_batch_size

          if current_size_batch != required_batch_size:
              del current_ckpt

              path_file_input_model_pt2 = export_checkpoint(
                  path_file_input_lightning_ckpt=path_file_model_ckpt_input,
                  path_file_output_compiled_pt2=None,
                  batch_size=required_batch_size,
              )

              current_ckpt = torch._inductor.aoti_load_package(path_file_input_model_pt2)
              current_size_batch = required_batch_size

          x = map(
              lambda y: load_bin_for_inference(path_file_fft_bin_input=y[0]),
              batch_path_file_tuple_output,
          )

          x = torch.cat(list(x))

          x = current_ckpt(x.to("cuda")).detach().cpu()

          y = [
              (
                  path_file_tuple_output,
                  x[i, ...].squeeze(0),
              )
              for (i, path_file_tuple_output) in enumerate(batch_path_file_tuple_output)
          ]

          z = map(lambda r: do_final_write(r[0], r[1]), y)
