**** Run an worker loop
#+begin_src python :shebang #!/usr/bin/env python3 :results output :mkdirp yes :tangle ./worker.function.py
  def worker_loop():
      os.makedirs(
          "/data/base_path/",
          exist_ok=True,
      )

      print("Starting inference loop")
      notifying_dataset = notify_dataset(path_dir_prefix_input="/data/base_path/")

      waittime_long = 10000
      batch_size_small = 4

      waittime_short = 200
      batch_size_large = 16

      waittime = waittime_long
      batch_size = batch_size_small

      start_time = time.monotonic()

      while True:
          list_file_hashes = set(
              i[:-5]
              for i in notifying_dataset(
                  batch_size=batch_size,
                  waittime=waittime,
              )
              if i.endswith(".work")
          )

          list_postgres_hashes = set(get_hash_list())

          if list_postgres_hashes:
              current_time = time.monotonic()
              elapsed_time = current_time - start_time
              run_full = elapsed_time > 60

              if not run_full:
                  list_intersection_hashes = list_file_hashes.intersection(
                      list_postgres_hashes
                  )

                  if list_intersection_hashes:
                      waittime = waittime_short
                      batch_size = batch_size_large
                      print(f"Processing {len(list_intersection_hashes)} videos...")
                      run_inference(list_intersection_hashes)

                      for i in list_file_hashes:
                          path_file_work = "/data/base_path/" + i + ".work"
                          if is_path_file(path_file_work):
                              os.unlink(path_file_work)
                  else:
                      run_full = True

              if run_full:
                  start_time = current_time
                  waittime = waittime_short
                  batch_size = batch_size_large
                  print(f"Processing {len(list_postgres_hashes)} videos...")
                  run_inference(list_postgres_hashes)

                  for i in list_postgres_hashes:
                      path_file_work = "/data/base_path/" + i + ".work"
                      if is_path_file(path_file_work):
                          os.unlink(path_file_work)

          else:
              waittime = waittime_long
              batch_size = batch_size_small
#+end_src

