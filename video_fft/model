#+begin_src python :shebang #!/usr/bin/python3 :results output :tangle ./main.class.py
  class classifier_transformer(torch.nn.Module):
      def __init__(self):
          super().__init__()
          self.inshape = [
              N_CHANNELS_FFT,
              SIZE_TRUNCATED,
              SIZE_TRUNCATED,
              N_FFT_MODES_T,
          ]

          self.attention_shape = [
              SIZE_TRUNCATED >> 1,
              SIZE_TRUNCATED >> 1,
              (N_FFT_MODES_T * N_CHANNELS_FFT) << 2,
          ]

          self.attention_head = torch.nn.ModuleList(
              [ST_attentin_head(self.attention_shape) for _ in range(8)],
          )

          self.norm_final = torch.nn.LayerNorm(self.attention_shape[-1])

          self.head = torch.nn.Linear(
              self.attention_shape[-1],
              N_CLASS_OUTPUT,
          )

      def forward(self, batch_x):
          """
          batch_x => torch.tensor [6, 160, 160, 60]
          """
          batch_x = einops.rearrange(
              batch_x,
              "B C (H BH) (W BW) T -> B H W (C T BH BW)",
              BH=2,
              BW=2,
          )

          for i in self.attention_head:
              batch_x = i(batch_x)

          batch_x = batch_x.mean(dim=(1, 2))
          batch_x = self.norm_final(batch_x)
          batch_x = self.head(batch_x)

          return batch_x
#+end_src

