  class AutoModeProcessor:
      def __init__(self):
          os.makedirs(DOWNLOAD_DIR, exist_ok=True)

          # 1. Warm up the model (Loaded once at deployment start)
          logger.info("Initializing inference engine...")
          # self.slave = infer_slave(path_file_ckpt_input="/data/output/model.ckpt")

          # 2. Initialize GCP Client
          self.storage_client = None
          if os.path.exists(SERVICE_ACCOUNT_KEY_PATH):
              try:
                  creds = service_account.Credentials.from_service_account_file(
                      SERVICE_ACCOUNT_KEY_PATH
                  )
                  self.storage_client = storage.Client(credentials=creds)
                  logger.info("GCP Storage client initialized successfully.")
              except Exception as e:
                  logger.error(f"Failed to initialize GCP client: {e}")
          else:
              logger.warning(
                  f"Service account key not found at {SERVICE_ACCOUNT_KEY_PATH}"
              )

      def _download_from_gcs(self, gcs_uri: str, filename: str) -> str:
          if not self.storage_client:
              raise RuntimeError("GCP Client not active. Check service-account-key.json.")

          # Parse gs://bucket/blob
          uri_path = gcs_uri.replace("gs://", "")
          bucket_name, blob_name = uri_path.split("/", 1)

          bucket = self.storage_client.bucket(bucket_name)
          blob = bucket.blob(blob_name)

          local_path = os.path.join(DOWNLOAD_DIR, filename)
          blob.download_to_filename(local_path)
          return local_path

      async def _save_upload(self, upload_file, filename: str) -> str:
          local_path = os.path.join(DOWNLOAD_DIR, filename)
          content = await upload_file.read()
          with open(local_path, "wb") as f:
              f.write(content)
          return local_path

      async def __call__(self, request: Request):
          unique_name = f"{uuid.uuid4()}.mp4"
          local_path = None
          content_type = request.headers.get("content-type", "")

          try:
              # --- 1. Data Ingestion ---
              if "application/json" in content_type:
                  data = await request.json()
                  if "gcs_uri" not in data:
                      return {"error": "Missing 'gcs_uri' in JSON body"}
                  local_path = self._download_from_gcs(data["gcs_uri"], unique_name)

              elif "multipart/form-data" in content_type:
                  form = await request.form()
                  if "file" not in form:
                      return {"error": "Missing 'file' in multipart form"}
                  local_path = await self._save_upload(form["file"], unique_name)

              else:
                  return {"error": "Unsupported Content-Type. Use JSON or Multipart."}

              # --- 2. Inference ---
              # We pass the specific file path to avoid race conditions
              # if multiple files exist in the input directory.
              logger.info(f"Processing file: {local_path}")

              # Assuming your slave function takes a file path or dir

              # self.slave('/data/input')

              # local_json_path = local_path[:-3] + "json"
              result = run_RD_compile_and_infer(
                  path_file_input_model_ckpt="/data/input/model.ckpt",
                  path_file_video_input=local_path,
              )
              # json.load(fp=open(local_json_path, "r", encoding="utf-8"))
              os.unlink(local_path)
              return {"status": "success", "filename": unique_name, "result": result}

          except Exception as e:
              logger.error(f"Inference error: {str(e)}")
              return {"status": "error", "message": str(e)}

