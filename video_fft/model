  def run_inference(list_hash_key):
      if not list_hash_key:
          return []

      list_path_file_video_input = map(
          get_path_file_video_from_hash_key,
          list_hash_key,
      )
      list_path_file_video_input = filter(
          is_path_file_video,
          list_path_file_video_input,
      )
      list_path_file_video_input = list(list_path_file_video_input)

      list_path_file_json_output = map(
          convert_path_file_video_2_path_file_json,
          list_path_file_video_input,
      )
      list_path_file_json_output = list(list_path_file_json_output)

      list_path_file_safetensors = map(
          convert_path_file_video_2_path_file_safetensors,
          list_path_file_video_input,
      )
      list_path_file_safetensors = list(list_path_file_safetensors)

      try:
          with pool.connection() as conn:
              with conn.transaction():
                  with conn.cursor() as cur:
                      print("Requesting GPU lock...")
                      cur.execute("SELECT pg_advisory_xact_lock(%s)", (GPU_LOCK_ID_1,))
                      print("GPU lock acquired. Starting inference...")

                      infer_on_list_path_file_video(
                          list_path_file_video_input=list_path_file_video_input,
                          size_batch=4,
                          path_file_model_ckpt_input="/data/input/model.ckpt",
                      )

                      print("Inference complete. Releasing GPU lock.")

          list_pred_dict = map(read_json_file, list_path_file_json_output)
          list_pred_dict = list(list_pred_dict)

          push_result(list_hash_key, list_pred_dict)

          def safe_unlink_list(list_path_file_input):
              s1 = filter(is_path_file, list_path_file_input)
              s2 = map(os.unlink, list_path_file_input)
              list(s2)

          safe_unlink_list(list_path_file_input=list_path_file_safetensors)
          safe_unlink_list(list_path_file_input=list_path_file_video_input)
          safe_unlink_list(list_path_file_input=list_path_file_json_output)

          return list_path_file_video_input

