  class SwiGLU(torch.nn.Module):
      def __init__(self, dimension):
          super().__init__()
          self.linear_1 = torch.nn.Linear(dimension, dimension)
          self.linear_2 = torch.nn.Linear(dimension, dimension)

      def forward(self, x):
          output = self.linear_1(x)
          swish = output * torch.sigmoid(output)
          swiglu = swish * self.linear_2(x)

          return swiglu
