* Code from gemini
#+begin_src conf :mkdirp yes :tangle ./prompt.txt
  I have a tensor of the form [Channel = 3, Height = 720, Width = 1280, Time = 160]
  which represents a video clip of 20 seconds at 8 FPS.
  I want to do full 4D fft (including the channel dimension).
  Truncate the height and width dimensions to 1/8 of the original size.
  Truncate the time dimension to keep only the modes whose frequencies are less than 3 hz.
  Keep all 3 channels (after fft).
  Give code for this in pytorch
  prefer using rfft as input will be real tensor.
#+end_src

#+begin_src python :shebang #!/usr/bin/env python3 :results output :mkdirp yes :tangle ./gemini.py
  import torch
  import torch.fft


  def compress_video_fft():
      # --- CONFIGURATION ---
      C, H, W, T = 3, 720, 1280, 160
      fps = 8.0

      # Generate dummy video tensor: [Channel, Height, Width, Time]
      video_tensor = torch.randn(C, H, W, T)
      print(f"Original Shape: {video_tensor.shape}")

      # --- 1. Perform 4D Real FFT ---
      # We transform over dimensions 0, 1, 2, 3 (Channel, Height, Width, Time).
      # rfftn expects the last dim in 'dim' to be the one that becomes the complex half-dimension.
      # Result is complex64 or complex128.
      fft_video = torch.fft.rfftn(video_tensor, dim=(0, 1, 2, 3))

      # --- 2. Shift Spatial/Channel Frequencies ---
      # We shift dimensions 0, 1, 2 (C, H, W) to move low frequencies to the center.
      # We DO NOT shift dim 3 (Time) because rfftn output starts at 0 Hz for that dimension.
      fft_shifted = torch.fft.fftshift(fft_video, dim=(0, 1, 2))

      # --- 3. Calculate Truncation Indices ---

      # A. Spatial Truncation (Keep center 1/8)
      # Height
      target_h = H // 8  # 90
      start_h = (H // 2) - (target_h // 2)
      end_h = start_h + target_h

      # Width
      target_w = W // 8  # 160
      start_w = (W // 2) - (target_w // 2)
      end_w = start_w + target_w

      # B. Time Truncation (Keep modes < 3 Hz)
      # Freq Resolution = FPS / Total_Frames = 8 / 160 = 0.05 Hz
      # Cutoff Index = 3.0 Hz / 0.05 Hz = 60
      # We slice up to 60 (exclusive) to keep frequencies 0.0 to 2.95 Hz.
      freq_res = fps / T
      time_cutoff_idx = int(3.0 / freq_res)

      # --- 4. Apply Truncation ---
      # Dimensions: [Channel, Height, Width, Time]
      # Channel: Keep all (:)
      # Height: Keep center 90 indices
      # Width: Keep center 160 indices
      # Time: Keep first 60 indices (0 to ~3Hz)
      compressed_fft = fft_shifted[:, start_h:end_h, start_w:end_w, :time_cutoff_idx]

      print(f"Compressed FFT Shape: {compressed_fft.shape}")
      # Expected: [3, 90, 160, 60]

      return compressed_fft


  # Run the function
  output = compress_video_fft()
#+end_src

