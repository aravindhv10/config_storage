  class lightning_wrapper(lightning.LightningModule):
      def configure_optimizers(self):
          optimizer = torch.optim.AdamW(
              self.model.parameters(),
              lr=LR,
          )

          return optimizer

      def training_step(self, batch, batch_idx):
          (x, y, p) = batch
          r = self.forward(x)
          d = self.loss(r, y)
          print(y, p, r, d)
          self.log("train_loss", d)
          return d

      def val_test_step(self, batch, batch_idx, step_label):
          (x, y, p) = batch
          batch_size = x.shape[0]
          r = self.model(x)
          (l, t) = get_weighted_accuracy_refweight(X=r, Y=y, W=self.weights_tensor)
          self.log(
              step_label,
              l,
              batch_size=batch_size * t,
              sync_dist=True,
          )

      def do_compile(self):
          self.model = torch.compile(
              self.model,
              mode="max-autotune",
          )

      def test_step(self, batch, batch_idx):
          self.val_test_step(batch=batch, batch_idx=batch_idx, step_label="test_accuracy")

      def validation_step(self, batch, batch_idx):
          self.val_test_step(batch=batch, batch_idx=batch_idx, step_label="val_accuracy")

      def predict_step(self, batch, batch_idx):
          return self.model(batch)

      def forward_net(self, x):
          if self.for_training:
              return self.model(x)
          else:
              y = self.model(x)
              y = torch.nn.functional.softmax(y, dim=1)
              return y

      def set_forward_net(self):
          self.forward = self.forward_net

      def forward_with_fft(self, x):
          x = torch.nn.functional.pad(
              input=x,
              pad=(
                  0,
                  0,
                  0,
                  0,
                  0,
                  560,
              ),
          )

          x = torch.permute(
              x,
              (
                  3,
                  1,
                  2,
                  0,
              ),
          )

          x = torch.fft.rfftn(x)

          x = x[
              :,
              :,
              :,
              0:60,
          ]

          x = torch.fft.fftshift(
              x,
              dim=(
                  0,
                  1,
                  2,
              ),
          )

          x = x[
              :,
              560:720,
              560:720,
              :,
          ]

          x = torch.cat(
              (
                  x.abs(),
                  x.angle(),
              )
          )

          x = torch.nn.functional.interpolate(
              input=x.unsqueeze(0),
              size=(
                  160,
                  160,
                  60,
              ),
              mode="trilinear",
          ).squeeze()

          x = (x - self.tensor_mu) / self.tensor_sigma
          x = x.unsqueeze(0).to(dtype=torch.float32)
          x = self.model(x)
          x = torch.nn.functional.softmax(
              x,
              dim=1,
          )
          return x

      def set_forward_with_fft(self):
          self.forward = self.forward_with_fft
          self.register_buffer("tensor_mu", tensor_mu)
          self.register_buffer("tensor_sigma", tensor_sigma)

      def __init__(self, for_training=True):
          super().__init__()
          self.model = classifier()
          self.for_training = for_training
          if self.for_training:
              write_classes_json_if_not_exist(path_dir_prefix_input="/data/input/train/")
              slave = reweight_calculator_bin(
                  path_file_label_json_input="/data/input/train/labels.json"
              )
              self.weights_tensor = slave.get_tensor()
              self.weights_tensor[0] *= 2.0
              self.weights_tensor[1] /= 16.0
              print(self.weights_tensor)
          else:
              self.weights_tensor = (
                  torch.ones((N_CLASS_OUTPUT), dtype=torch.float32) + 0.1
              )
          self.loss = torch.nn.CrossEntropyLoss(weight=self.weights_tensor)
          print("Weights: ", self.weights_tensor)
          self.set_forward_net()
