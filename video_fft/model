*** Main class for tensor augmentations
#+begin_src python :shebang #!/usr/bin/python3 :results output :tangle ./main.class.py
  class augmenter:
      def __init__(self, for_training):
          self.for_training = for_training
          self.shape = [
              N_CHANNELS_FFT,
              SIZE_TRUNCATED,
              SIZE_TRUNCATED,
              N_FFT_MODES_T,
          ]

      def do_blur(self, x, f=None):
          if f is None:
              f = (
                  1
                  - torch.abs(
                      torch.normal(mean=torch.zeros(1), std=torch.ones(1) * 0.2)
                  ).item()
              )
              f = max(f, 0.4)

          x = torch.nn.functional.interpolate(
              input=x.unsqueeze(0),
              size=(
                  int(SIZE_TRUNCATED * f),
                  int(SIZE_TRUNCATED * f),
                  int(N_FFT_MODES_T * f),
              ),
              mode="trilinear",
          )

          x = torch.nn.functional.interpolate(
              input=x,
              size=(
                  SIZE_TRUNCATED,
                  SIZE_TRUNCATED,
                  N_FFT_MODES_T,
              ),
              mode="trilinear",
          ).squeeze(0)

          return x

      def __call__(self, x, i):
          if i > 1:
              print("Warning: it is not necessary to use i > 1")

          i = i & 1

          if i == 1:
              x = torch.permute(input=x, dims=(0, 2, 1, 3))

          if self.for_training:
              x = self.do_blur(x, f=None)

          return x
#+end_src

