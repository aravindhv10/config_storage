#+begin_src python :shebang #!/usr/bin/python3 :results output :tangle ./main.class.py
  class ST_attentin_head(torch.nn.Module):
      def get_device(self):
          return next(iter(self.parameters())).device

      def get_dtype(self):
          return next(iter(self.parameters())).dtype

      def prepare_ROPE_matrix(self, dim):
          d_theta = torch.pi / (2 * dim)
          mat_theta = torch.zeros(
              [dim, 2, 2],
              dtype=self.dtype,
          )
          for i in range(dim):
              theta = i * d_theta
              st = np.sin(theta)
              ct = np.cos(theta)
              mat = torch.tensor(
                  [[ct, -st], [st, ct]],
                  dtype=torch.float32,
              )
              mat_theta[i, :, :] = mat[:, :]
          return mat_theta

      def prepare_ROPE_W(self):
          self.register_buffer("ROPE_W", self.prepare_ROPE_matrix(self.len_W))

      def prepare_ROPE_H(self):
          self.register_buffer("ROPE_H", self.prepare_ROPE_matrix(self.len_H))

      def __init__(self, inshape):
          super().__init__()

          self.inshape = inshape
          self.out_dim_pow = get_closest_2_pow(x=self.inshape[-1])
          self.len_W = self.inshape[-2]
          self.len_H = self.inshape[-3]
          self.out_dim = 1 << self.out_dim_pow
          self.scale = self.out_dim**-0.5

          self.qkv = torch.nn.Linear(
              in_features=self.inshape[-1],
              out_features=self.out_dim * 3,
              bias=True,
          )

          self.swiglu = SwiGLU(self.out_dim)

          self.proj_out = torch.nn.Linear(
              in_features=self.out_dim,
              out_features=self.inshape[-1],
              bias=True,
          )

          self.norm = torch.nn.LayerNorm(self.out_dim)

          self.dtype = self.get_dtype()
          self.device = self.get_device()

          self.prepare_ROPE_W()
          self.prepare_ROPE_H()

      def forward(self, x):
          y = self.qkv(x)
          y = einops.rearrange(y, "B Y X (T D) -> D B Y X T", D=3)
          q = y[0]
          k = y[1]
          v = y[2]

          q = einops.rearrange(
              q,
              "B Y X (YR XR D) -> B Y X YR XR D",
              YR=2,
              XR=2,
          )
          q = einops.einsum(
              self.ROPE_W,
              q,
              "X XF XR , B Y X YR XR D -> B Y X YR XF D",
          )
          q = einops.einsum(
              self.ROPE_H,
              q,
              "Y YF YR , B Y X YR XF D -> B Y X YF XF D",
          )
          q = einops.rearrange(
              q,
              "B Y X YF XF D -> B (Y X) (YF XF D)",
          )
          q = q * self.scale

          k = einops.rearrange(
              k,
              "B Y X (YR XR D) -> B Y X YR XR D",
              YR=2,
              XR=2,
          )
          k = einops.einsum(
              self.ROPE_W,
              k,
              "X XF XR , B Y X YR XR D -> B Y X YR XF D",
          )
          k = einops.einsum(
              self.ROPE_H,
              k,
              "Y YF YR , B Y X YR XF D -> B Y X YF XF D",
          )
          k = einops.rearrange(
              k,
              "B Y X YF XF D -> B (Y X) (YF XF D)",
          )
          v = einops.rearrange(
              v,
              "B Y X D -> B (Y X) D",
          )

          attn = einops.einsum(q, k, "B S1 D, B S2 D -> B S1 S2")
          del q
          del k
          del y
          attn = attn.softmax(dim=-1)

          y = einops.einsum(attn, v, "B S1 S2, B S2 D -> B S1 D")
          y = self.norm(y)
          y = self.swiglu(y)
          y = self.proj_out(y)
          y = y.reshape(list(x.shape))

          return y + x
#+end_src

